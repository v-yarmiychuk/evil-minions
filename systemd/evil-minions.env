# This file is a part of Evil Minion.
# systemd service environment file with additional options.
#

# Amount of the Evil Minions
COUNT=1000

# Verbosity [ DEBUG | INFO| WARN | ERROR | CRITICAL ]
LOG_LEVEL=INFO

# Location of persistent keys
EVIL_MINIONS_PKI_BASE=/var/lib/evil-minions/pki

# Involve mock grains profiles
EVIL_MINIONS_GRAINS_PROFILES=/opt/saltstack/evil-minions/data/grains.json
EVIL_MINIONS_REQUIRE_GRAINS_PROFILES=true

# Take names for minions from the mock grains profile
EVIL_MINIONS_ID_SOURCE=profile

# Avoid duplicated names
EVIL_MINIONS_ENFORCE_UNIQUE_IDS=true
