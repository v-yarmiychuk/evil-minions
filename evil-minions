#!/usr/bin/python3
'''
Script to start a salt-minion that will act as many minions (from salt-master's
point of view).
Every response sent by the minion will be replicated and sent out separately
to the master with different minion ids, as if multiple minions were connected
and responding in the same way.
'''

import argparse
import logging
import os
import shutil
import sys
import time

# Salt onedir packages ship their own Python; re-exec into it when needed.
if not os.environ.get("EVIL_MINIONS_BOOTSTRAPPED"):
    try:
        import salt  # noqa: F401
    except ImportError:
        onedir_python = "/opt/saltstack/salt/bin/python3.10"
        if os.path.exists(onedir_python):
            os.environ["EVIL_MINIONS_BOOTSTRAPPED"] = "1"
            os.execv(onedir_python, [onedir_python, os.path.abspath(__file__), *sys.argv[1:]])
from multiprocessing import Process, cpu_count, Semaphore

from evilminions.proxy import start_proxy
from evilminions.vampire import Vampire
from evilminions.hydra import Hydra


def hydra_process_count(minion_count, processes):
    '''Worker processes for Hydras; ``processes`` if given, else from minion_count.'''
    ncpu = cpu_count()
    if processes is not None:
        return max(1, min(minion_count, processes))
    if minion_count < 1:
        return 1
    if minion_count < 150:
        return max(1, min(minion_count, ncpu))
    per_worker = 100
    p = (minion_count + per_worker - 1) // per_worker
    p = max(ncpu, p)
    p = min(p, minion_count, 56)
    return max(1, p)


def mimic_poll_interval(minion_count, seconds):
    '''Sleep in mimic() while waiting for baseline; ``seconds`` is --mimic-poll when set.'''
    if seconds is not None:
        return max(0.01, float(seconds))
    if minion_count <= 200:
        return 0.05
    extra = min(0.03, max(0, minion_count - 200) / 25000.0)
    return min(0.08, 0.05 + extra)


def main():
    # parse commandline switches
    parser = argparse.ArgumentParser(description='Starts a salt-minion and many evil minions that mimic it.')
    parser.add_argument('--count', dest='count', type=int, default=100,
                       help='number of evil minions (default: 100)')
    parser.add_argument('--ramp-up-delay', dest='ramp_up_delay', type=float, default=0.0,
                       help='time between evil minion starts in seconds, supports fractions (default: 0.0)')
    parser.add_argument('--processes', dest='processes', type=int, default=None,
                       help='Hydra worker process count (default: from --count)')
    parser.add_argument('--log-level', dest='log_level', default='INFO',
                       choices=['DEBUG', 'INFO', 'WARNING', 'ERROR', 'CRITICAL'],
                       help='log level (default: INFO)')
    args, remaining_args = parser.parse_known_args()

    os.environ['EVIL_MINIONS_LOG_LEVEL'] = args.log_level
    logging.basicConfig(
        level=getattr(logging, args.log_level),
        format='%(levelname)s:%(message)s',
    )
    log = logging.getLogger(__name__)
    log.debug("Starting evil-minions, setting up infrastructure...")

    proc_count = hydra_process_count(args.count, args.processes)
    mimic_poll = mimic_poll_interval(args.count, None)
    log.debug("count=%d hydra_workers=%d mimic_poll=%.3fs", args.count, proc_count, mimic_poll)

    # set up Hydras, one per process. Hydras are so called because they have
    # many HydraHeads, each HydraHead running one evil-minion
    semaphore = Semaphore(0)
    chunks = minion_chunks(args.count, proc_count)
    hydras = [Process(target=Hydra(i).start, kwargs={
        'hydra_count': len(chunks),
        'chunk': chunk,
        'ramp_up_delay': args.ramp_up_delay,
        'slowdown_factor': 0.0,
        'random_slowdown_factor': 0.0,
        'keysize': 2048,
        'mimic_poll_interval': mimic_poll,
        'semaphore': semaphore
    }) for i, chunk in enumerate(chunks)]

    for hydra in hydras:
        hydra.start()

    for hydra in hydras:
        semaphore.acquire()

    # set up Vampire, to intercept messages from the original minion and send them to Proxy
    vampire = Vampire()
    vampire.attach()

    # set up Proxy, to route messages from Vampire to Hydras
    proxy = Process(target=start_proxy, kwargs={'semaphore': semaphore})
    proxy.start()
    semaphore.acquire()
    # Brief pause so PUB subscribers finish handshaking before real minion traffic.
    time.sleep(0.5)

    # restore salt-minion's orignal command line args and launch it
    sys.argv = [sys.argv[0]] + remaining_args
    salt_minion_executable = shutil.which('salt-minion')
    exec(compile(open(salt_minion_executable).read(), salt_minion_executable, 'exec'))

def minion_chunks(count, processes):
    '''Returns chunks of minion indexes, per process (eg. 4 minions and 3 processes: [[0, 1], [2], [3]])'''
    minions_per_process = count // processes
    rest = count % processes
    lengths = [minions_per_process + 1] * rest + [minions_per_process] * (processes - rest)
    starts = [sum(lengths[:i]) for i in range(processes)]

    indexes = list(range(count))

    return [indexes[starts[i]:starts[i] + lengths[i]] for i in range(processes)]

if __name__ == "__main__":
    main()
